# ─── Copy this to apps/backend/.env and fill in your values ──────────────────
# DO NOT commit .env to git
#
# REQUIRED vars (marked with [required]) — the app refuses to start without them.
# OPTIONAL vars — features degrade gracefully when absent (email, payments).
#
# ── Supabase ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"  # [required]
DIRECT_URL="postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"                   # [required]
NEXT_PUBLIC_SUPABASE_URL="https://PROJECT_REF.supabase.co"                                                                    # [required]
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"                                                                             # [required]

# ── JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="replace-with-random-256-bit-hex-string"          # [required]
JWT_REFRESH_SECRET="replace-with-different-random-hex-string" # [required]
JWT_EXPIRES_IN="1h"
JWT_REFRESH_EXPIRES_IN="7d"

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT="3001"
FRONTEND_URL="http://localhost:3000"
# error | warn | log | debug | verbose (default: warn in production, debug in dev)
LOG_LEVEL="debug"

# ── Email (Resend) — optional, staff invitations degrade to console logs ──────
RESEND_API_KEY="re_your_api_key_here"
EMAIL_FROM="MyWAppStore <noreply@yourdomain.com>"

# ── Payments (Paystack) — optional, billing UI shows "not configured" ─────────
# Use test keys (sk_test_xxx) in development, live keys (sk_live_xxx) in production
PAYSTACK_SECRET_KEY="sk_test_your_key_here"
