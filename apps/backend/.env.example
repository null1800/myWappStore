# ─── Copy this to apps/backend/.env and fill in your values ──────────────────
# DO NOT commit .env to git
#
# Supabase CLI: run `npm run supabase:check` — .env project ref must match `supabase projects list`
# Repo is linked to purch (qqdnbyrrakfgvskhwega) if you ran link from this account.
#
# ── Option A: purch (CLI-linked on your account) ─────────────────────────────
# DATABASE_URL="postgresql://postgres.qqdnbyrrakfgvskhwega:YOUR_PASSWORD@aws-1-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.qqdnbyrrakfgvskhwega:YOUR_PASSWORD@aws-1-eu-central-1.pooler.supabase.com:5432/postgres"
# NEXT_PUBLIC_SUPABASE_URL="https://qqdnbyrrakfgvskhwega.supabase.co"
#
# ── Option B: other project (only if your CLI login owns it) ─────────────────
DATABASE_URL="postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"
NEXT_PUBLIC_SUPABASE_URL="https://PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="2433d15d1876e6979d6d777a53eef8ec99f57c9c04dbe010c6a02d149eca3a4e"
JWT_REFRESH_SECRET="replace-with-different-random-256-bit-hex-string"
JWT_EXPIRES_IN="1h"
JWT_REFRESH_EXPIRES_IN="7d"
NODE_ENV="development"
PORT="3001"
FRONTEND_URL="http://localhost:3000"
